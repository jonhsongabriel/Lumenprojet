# docker-compose.yml
version: '3.8'

services:
  # === NGINX : Reverse Proxy ===
  nginx:
    image: nginx:alpine
    ports:
      - "80:80"
    volumes:
      - ./nginx.conf:/etc/nginx/conf.d/default.conf:ro
      - ./react/build:/var/www/html:ro
    depends_on:
      - node
      - fastapi
    restart: unless-stopped

  # === NODE.JS : API + WebSocket ===
  node:
    build: ./node
    expose:
      - "3000"
    env_file:
      - .env
    environment:
      - NODE_ENV=production
      - PORT=3000
      - POSTGRES_URL=${POSTGRES_URL}
      - REDIS_URL=redis://redis:6379
    depends_on:
      - postgres
      - redis
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:3000/health"]
      interval: 30s
      timeout: 5s
      retries: 3

  # === FASTAPI : Analytique ===
  fastapi:
    build: ./fastapi
    expose:
      - "8000"
    command: gunicorn -k uvicorn.workers.UvicornWorker -w 4 --bind 0.0.0.0:8000 main:app
    env_file:
      - .env
    environment:
      - DATABASE_URL=${POSTGRES_URL}
      - REDIS_URL=redis://redis:6379
    depends_on:
      - postgres
      - redis
    restart: unless-stopped

  # === POSTGRESQL ===
  postgres:
    image: postgres:16-alpine
    expose:
      - "5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    environment:
      POSTGRES_DB: lumendb
      POSTGRES_USER: lumen
      POSTGRES_PASSWORD: Lum3n.pasS!
    restart: unless-stopped

  # === REDIS ===
  redis:
    image: redis:7-alpine
    expose:
      - "6379"
    command: redis-server --appendonly yes
    volumes:
      - redis_data:/data
    restart: unless-stopped

volumes:
  postgres_data:
  redis_data:
